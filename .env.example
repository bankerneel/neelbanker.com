# Copy to .env.local and fill in your values
# Never commit .env.local

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Resend Audience ID — https://resend.com/audiences
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Sender address for newsletter/subscription/download emails
NEWSLETTER_FROM_EMAIL="Neel Banker <insights@neelbanker.com>"

# Sender address for website enquiry emails and auto-replies
ENQUIRY_FROM_EMAIL="Neel Banker <inquiry@neelbanker.com>"

# Where contact form submissions are delivered
CONTACT_EMAIL=inquiry@neelbanker.com
